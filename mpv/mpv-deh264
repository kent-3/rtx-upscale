#!/bin/bash
# Launch native mpv with realtime DeH264 cleanup only.

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
REPO_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
MPV_BIN=${MPV_BIN:-}
CONCURRENT_FRAMES=${DEH264_CONCURRENT_FRAMES:-4}

if [[ -z "$MPV_BIN" ]]; then
    if [[ -x "$REPO_DIR/../mpv-native/bin/mpv" ]]; then
        MPV_BIN="$REPO_DIR/../mpv-native/bin/mpv"
    else
        MPV_BIN=mpv
    fi
fi

if [[ -d "$REPO_DIR/../mpv-native/lib" ]]; then
    export LD_LIBRARY_PATH="$REPO_DIR/../mpv-native/lib:${LD_LIBRARY_PATH:-}"
fi

if [[ -d "$REPO_DIR/.venv/lib/python3.12/site-packages" ]]; then
    export PYTHONPATH="$REPO_DIR/.venv/lib/python3.12/site-packages:${PYTHONPATH:-}"
fi

exec "$MPV_BIN" \
    --hwdec=nvdec-copy \
    --vo=gpu-next \
    --gpu-api=vulkan \
    --gpu-context=waylandvk \
    --video-sync=display-resample \
    --deband=yes \
    --vf="vapoursynth=file=$SCRIPT_DIR/deh264_direct.py:concurrent-frames=$CONCURRENT_FRAMES" \
    "$@"
